# [Required] Your DashScope API key
LLM_API_KEY=your_dashscope_api_key_here

# [Optional] Switch to fake engine for UI testing without API calls
# RAG_ENGINE_MODE=core

# [Optional] Change if your frontend runs on a different port
# FRONTEND_HOST=127.0.0.1

# [Optional] Change if backend port conflicts with other services
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000

# [Optional] CORS origins, change if deploying to remote server
# ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# [Optional] LLM model and endpoint
# LLM_MODEL=qwen-turbo
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1