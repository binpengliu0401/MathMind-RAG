# Runtime
APP_ENV=development
LOG_LEVEL=INFO

# Frontend
FRONTEND_PROTOCOL=http
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
FRONTEND_RAG_TRANSPORT=websocket

# Backend
BACKEND_PROTOCOL=http
BACKEND_WS_PROTOCOL=ws
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WS_PATH=/ws/rag
BACKEND_API_PREFIX=
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# RAG
RAG_ENGINE_MODE=fake
RAG_MAX_RETRIES=2
RAG_HALLUCINATION_THRESHOLD=0.7
RAG_TOP_K_DOCS=5
RAG_FAISS_INDEX_PATH=./data/faiss_index
DEBUG_STEP_DELAY_MS=250

# LLM
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.0
