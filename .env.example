APP_ENV=development
LOG_LEVEL=INFO

FRONTEND_PROTOCOL=http
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
FRONTEND_RAG_TRANSPORT=websocket

BACKEND_PROTOCOL=http
BACKEND_WS_PROTOCOL=ws
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WS_PATH=/ws/rag
BACKEND_API_PREFIX=
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

RAG_ENGINE_MODE=fake
RAG_MAX_RETRIES=2
RAG_HALLUCINATION_THRESHOLD=0.7
RAG_TOP_K_DOCS=5
RAG_FAISS_INDEX_PATH=./data/faiss_index
DEBUG_STEP_DELAY_MS=250

LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.0

# LLM_MODEL=qwen/qwen-turbo
LLM_MODEL_REWRITING=openai/gpt-4.1-mini
LLM_MODEL_GRADING=openai/gpt-4.1-mini
LLM_MODEL_GENERATION=openai/gpt-4.1
